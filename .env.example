# Copy this file to .env.local and fill in your values.

# ── AI (OpenRouter) ─────────────────────────────────────────────
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
AI_BASE_URL=https://openrouter.ai/api/v1

# Model used to read documents (must accept images).
# Comma-separated list = automatic fallbacks when a model is rate-limited.
# Premium option: anthropic/claude-sonnet-4.5
MODEL_VISION=google/gemma-4-31b-it:free,google/gemma-4-26b-a4b-it:free,nvidia/nemotron-nano-12b-v2-vl:free

# Model used for valuation reasoning.
# Premium option: anthropic/claude-sonnet-4.5
MODEL_REASONING=qwen/qwen3-next-80b-a3b-instruct:free,meta-llama/llama-3.3-70b-instruct:free,openai/gpt-oss-20b:free

# Web search grounding for price comparison (needs OpenRouter credits).
# "auto" = try web search and fall back to model knowledge if unavailable. "off" = disable.
WEB_SEARCH=auto

# ── Supabase (history + reference prices) ───────────────────────
# Project Settings → API. Run supabase/schema.sql first.
# The app works without these; history is simply disabled.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key
